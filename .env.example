# --- Monnify ---
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=MK_TEST_xxxxxxxxxx
MONNIFY_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MONNIFY_CONTRACT_CODE=xxxxxxxxxx
# Monnify disbursement source wallet account number (the account transfers are paid FROM)
MONNIFY_SOURCE_ACCOUNT_NUMBER=9999999999

# --- Database ---
DATABASE_URL=sqlite:///./padipot.db

# --- WhatsApp Cloud API (Meta, direct) ---
WHATSAPP_TOKEN=xxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxx
WHATSAPP_VERIFY_TOKEN=padipot_verify_me
WHATSAPP_API_VERSION=v20.0

# --- WhatsApp via Twilio (alternative transport) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
PUBLIC_BASE_URL=https://your-ngrok-domain.ngrok-free.app

# --- Africa's Talking (USSD + SMS) ---
AT_USERNAME=sandbox
AT_API_KEY=xxxxxxxxxx
AT_SENDER_ID=PADIPOT

# --- App behaviour ---
DEFAULT_LANGUAGE=en
GUARD_SWEEP_INTERVAL_SECONDS=120
REMINDER_CHECK_INTERVAL_SECONDS=3600
LOG_LEVEL=INFO
